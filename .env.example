POSTGRES_DB=compass
POSTGRES_USER=compass
POSTGRES_PASSWORD=compass

CORS_ORIGINS=http://compass-v2.local:8080,http://localhost:3000
NEXT_PUBLIC_API_URL=http://compass-v2.local:8080/api

# Jira Cloud — agile_digests pulls feature metadata via the REST API
JIRA_BASE_URL=""
JIRA_EMAIL=""
JIRA_API_TOKEN=""
# Optional: override TTL (seconds) and target-end custom field name candidates
JIRA_CACHE_TTL_SECONDS=86400
JIRA_TARGET_END_FIELD_NAMES=Target end date,Target end